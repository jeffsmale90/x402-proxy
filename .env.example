# Private key of the proxy EOA. This account:
#  - receives ERC-7710 settlements (it is the payTo of the wrapped payment option)
#  - signs EIP-3009 transferWithAuthorization payments to upstream x402 services
# Fund it with a small USDC float on the networks you intend to proxy.
PRIVATE_KEY=0x...

# Port the proxy listens on
PORT=4021

# Maximum request/response body size buffered by the proxy
MAX_BODY_SIZE=10mb

# ERC-7710 facilitator URLs are hardcoded in src/facilitators.ts for:
#   Ethereum mainnet/sepolia, Base mainnet/sepolia, Linea mainnet/sepolia,
#   Monad mainnet/testnet, Arbitrum mainnet/sepolia
